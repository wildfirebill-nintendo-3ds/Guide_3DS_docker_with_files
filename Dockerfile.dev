# Development Dockerfile with hot-reload
FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy source files
COPY docs/ ./docs/
COPY crowdin.yaml ./
COPY clean_translations.py ./
COPY rss.py ./

# Create data directory
RUN mkdir -p /app/data/{backups,cache,logs}

# Expose VitePress dev port
EXPOSE 5173

# Start dev server with hot-reload
CMD ["npm", "run", "docs:dev", "--", "--host", "0.0.0.0"]
